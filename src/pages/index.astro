---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all published or updated posts
const allPosts = await getCollection('blog');

// Sort by date descending
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// We can just use all of them or slice.
const postsToShow = allPosts.slice(0, 6);
---

<BaseLayout>
  <div class="space-y-24 md:space-y-32">
    
    <!-- Hero Section (Asimétrico y deconstructivo) -->
    <section class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Lado izquierdo (Texto) -->
      <div class="flex flex-col gap-6">
        <h1 class="text-5xl md:text-[5rem] font-black text-white tracking-tighter leading-[1.05] uppercase">
          La verdad del octágono. <br class="hidden md:block"/> Sin clickbait.
        </h1>
        <p class="text-xl text-zinc-400 leading-relaxed max-w-xl">
          Soy Roger Murillo. SEO, practicante de BJJ y analista técnico de MMA. Aquí desgloso la técnica, la mente y el camino del guerrero.
        </p>
        <div class="mt-4">
          <a href="/categoria/analisis" class="btn-primary inline-block">Leer Análisis</a>
        </div>
      </div>
      
      <!-- Lado derecho (Visual) -->
      <div class="relative w-full aspect-square bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden grayscale group">
        <!-- Placeholder for actual image or dynamic img -->
        <div class="absolute inset-0 flex items-center justify-center text-zinc-700 font-bold uppercase tracking-widest group-hover:scale-105 transition-transform duration-700">
          [ Espacio para Foto de Entrenamiento ]
        </div>
        <!-- Si hubiera imagen real:
        <img src="/foto-entrenamiento.jpg" alt="Roger Murillo entrenando BJJ" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        -->
        <div class="absolute inset-0 bg-gradient-to-tr from-zinc-950/80 to-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- Sección "Últimos Artículos" -->
    <section class="max-w-7xl mx-auto border-t border-zinc-800/50 pt-16">
      <header class="mb-10 border-l-4 border-red-600 pl-4">
        <h2 class="text-3xl font-black text-white uppercase tracking-tight">Últimos Análisis</h2>
      </header>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {postsToShow.map((post, index) => (
          <ArticleCard article={post} large={index === 0 && postsToShow.length % 2 !== 0 ? false : false} />
        ))}
      </div>
    </section>
    
  </div>
</BaseLayout>

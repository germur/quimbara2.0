---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags?.includes(tag));
    return {
      params: { etiqueta: tag },
      props: { posts: filteredPosts },
    };
  });
}

const { etiqueta } = Astro.params;
const { posts } = Astro.props;

// Sort by date descending
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = `Etiqueta: #${etiqueta}`;
---

<BaseLayout title={title} description={`Artículos etiquetados con ${etiqueta}`}>
  <div class="space-y-8">
    <header class="mb-12 border-b border-zinc-800 pb-8">
      <div class="text-zinc-500 text-sm font-medium uppercase tracking-wider mb-2">Etiqueta</div>
      <h1 class="text-4xl md:text-5xl font-black text-white uppercase">#{etiqueta}</h1>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <ArticleCard article={post} />
      ))}
    </div>
  </div>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import TacticalSlider from '../../components/TacticalSlider.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const {
  title,
  description,
  author,
  pubDate,
  image,
  category,
  tags,
} = post.data;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).href;

// Date format
const dtf = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
});
const publishDateStr = dtf.format(pubDate);

const readTime = "8 min lectura"; // Placeholder

// Schema JSON-LD
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": { 
    "@type": "Person", 
    "name": author,
    "url": new URL("/", Astro.url.origin).href
  },
  "publisher": {
    "@type": "Organization",
    "name": "Quimbara",
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/favicon.svg", Astro.url.origin).href
    }
  },
  "datePublished": pubDate.toISOString(),
  "image": image ? new URL(image, Astro.url.origin).href : undefined
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": new URL("/", Astro.url.origin).href
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": category,
      "item": new URL(`/categoria/${category}/`, Astro.url.origin).href
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonicalUrl
    }
  ]
};

const combinedSchema = `[${JSON.stringify(articleSchema)}, ${JSON.stringify(breadcrumbSchema)}]`;
---

<BaseLayout 
  title={title} 
  description={description} 
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImage={image}
  publishDate={pubDate}
  schema={combinedSchema}
>
  <!-- Progress Bar Ficticia -->
  <div slot="progress-bar" class="fixed top-0 left-0 h-1 bg-red-600 z-[60] w-1/3"></div>

  <!-- Contenedor Principal de Lectura -->
  <div class="max-w-3xl mx-auto px-4 pt-12 pb-24 w-full">
    
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="text-sm text-zinc-500 mb-8 font-medium">
      <a href="/" class="hover:text-zinc-300 transition-colors">Inicio</a> 
      <span class="mx-2">/</span> 
      <a href={`/categoria/${category.toLowerCase()}/`} class="hover:text-zinc-300 transition-colors">{category}</a> 
      <span class="mx-2">/</span> 
      <span class="text-zinc-400">{title}</span>
    </nav>

    <!-- Cabecera del Artículo -->
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-black text-white uppercase leading-tight tracking-tight mb-6">
        {title}
      </h1>
      
      <!-- Meta Info -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-zinc-400 mb-8 pb-8 border-b border-zinc-800 uppercase tracking-wide">
        <time datetime={pubDate.toISOString()}>{publishDateStr}</time>
        <span>&middot;</span>
        <span>{readTime}</span>
        <span>&middot;</span>
        <span class="text-zinc-300 font-bold">{author}</span>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-3 mb-12">
          {tags.map(eq => (
            <Tag name={eq} />
          ))}
        </div>
      )}
    </header>

    <!-- Cover Image -->
    {image && (
      <div class="mb-12 w-full overflow-hidden rounded-xl border border-zinc-800">
        <img 
          src={image} 
          alt={`Portada de ${title}`} 
          class="w-full h-auto object-cover max-h-[500px]" 
        />
      </div>
    )}

    <!-- Cuerpo del contenido (Prose) -->
    <article class="prose prose-invert prose-zinc prose-headings:text-white prose-a:text-red-500 hover:prose-a:text-red-400 max-w-3xl mx-auto mt-10 prose-headings:uppercase prose-headings:tracking-tight prose-a:no-underline prose-img:rounded-xl">
      <Content components={{ TacticalSlider }} />
    </article>

    <!-- Bloque de Autor (E-E-A-T SEO) -->
    <div class="mt-24 p-8 bg-zinc-900 border border-zinc-800 rounded-xl flex flex-col md:flex-row items-center md:items-start gap-6">
      <div class="w-20 h-20 bg-zinc-800 rounded-full flex-shrink-0 flex items-center justify-center text-3xl font-black text-zinc-600">
        <!-- Initials as placeholder for avatar -->
        {author.split(' ').map(n=>n[0]).join('')}
      </div>
      <div>
        <h3 class="text-xl font-bold text-white mb-2">Escrito por {author}</h3>
        <p class="text-zinc-400 leading-relaxed text-sm">
          Especialista en SEO, practicante de Jiu-Jitsu Brasileño y analista técnico de Artes Marciales Mixtas. Con un enfoque meticuloso en la biomecánica y estrategia de combate, desglosa el juego de los campeones mundiales para entender qué sucede realmente dentro del octágono.
        </p>
      </div>
    </div>

  </div>
</BaseLayout>

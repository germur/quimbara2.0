---
// src/components/Tag.astro
interface Props {
  name: string;
  url?: string;
}

const { name, url = `/etiqueta/${name}/` } = Astro.props;
---

<a href={url} class="inline-block px-3 py-1 bg-zinc-800/50 text-zinc-400 text-sm font-medium rounded-full border border-zinc-700/50 backdrop-blur-sm transition-colors duration-300 hover:bg-zinc-800 hover:text-amber-500 hover:border-amber-500/50">
  {name}
</a>

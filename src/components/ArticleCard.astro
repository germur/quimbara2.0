---
// src/components/ArticleCard.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'blog'>;
  large?: boolean; // For the featured article in Bento Grid
}

const { article, large = false } = Astro.props;
const { title, category, pubDate, image } = article.data;

// Format date
const dtf = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
});
const formattedDate = dtf.format(pubDate);

// Mock read time since we don't have remark plugin setup yet
const readTime = "5 min"; 

// Category badge colors directly using Tailwind v4 theme variables defined in CSS
const badgeColors = {
  'Análisis': 'text-zinc-400 border-zinc-700 hover:text-red-500',
  'Historias': 'text-zinc-400 border-zinc-700 hover:text-red-500',
  'Opinión': 'text-amber-500 border-amber-500/50 hover:text-amber-400',
};

const badgeClass = badgeColors[category as keyof typeof badgeColors] || 'text-zinc-500 border-zinc-700';
---

<a href={`/blog/${article.id}/`} class="block group">
  <article class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden group hover:-translate-y-1 hover:border-red-600/50 transition-all duration-300 flex flex-col h-full">
    {image && (
      <div class={`relative w-full overflow-hidden ${large ? 'h-64 md:h-96' : 'h-48'}`}>
        <!-- Using standard img for now to easily support absolute URLs or local public images without static imports. -->
        <img 
          src={image} 
          alt={`Portada de ${title}`} 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
          loading={large ? "eager" : "lazy"} 
        />
      </div>
    )}
    <div class={`p-4 md:p-6 flex flex-col flex-grow ${large ? 'md:p-8' : ''}`}>
      <span class={`w-fit px-3 py-1 mb-4 text-xs font-bold uppercase tracking-wider border rounded-full backdrop-blur-sm transition-colors duration-300 ${badgeClass}`}>
        {category}
      </span>
      <h2 class={`font-bold tracking-tight uppercase line-clamp-2 text-white group-hover:text-red-500 transition-colors duration-300 mb-auto ${large ? 'text-2xl md:text-4xl' : 'text-lg md:text-xl'}`}>
        {title}
      </h2>
      <div class="mt-4 text-xs font-medium text-zinc-500 flex items-center gap-2 uppercase tracking-wide">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span>&middot;</span>
        <span>{readTime}</span>
      </div>
    </div>
  </article>
</a>

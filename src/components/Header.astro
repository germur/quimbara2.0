---
// src/components/Header.astro
const activePath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-white font-black text-2xl tracking-tight transition-all duration-300 hover:opacity-80 flex items-baseline">
      QUIMBARA<span class="text-red-600">.</span>
    </a>

    <!-- Mobile Menu Toggle (Checkbox Hack) -->
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-zinc-300 hover:text-white transition-all duration-300 z-50">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block peer-checked:hidden">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden peer-checked:block">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </label>

    <!-- Navigation -->
    <nav class="absolute top-[64px] left-0 w-full bg-zinc-950/95 backdrop-blur-md border-b border-zinc-800 p-6 flex flex-col gap-6 transform -translate-y-[150%] opacity-0 transition-all duration-300 peer-checked:translate-y-0 peer-checked:opacity-100 md:static md:w-auto md:bg-transparent md:border-none md:p-0 md:flex-row md:items-center md:gap-8 md:transform-none md:opacity-100 uppercase text-sm font-bold tracking-wider">
      <a href="/categoria/analisis" class={`transition-all duration-300 hover:text-red-500 ${activePath.includes('/analisis') ? 'text-white' : 'text-zinc-300'}`}>Análisis</a>
      <a href="/categoria/historias" class={`transition-all duration-300 hover:text-red-500 ${activePath.includes('/historias') ? 'text-white' : 'text-zinc-300'}`}>Historias</a>
      <a href="/categoria/opinion" class={`transition-all duration-300 hover:text-red-500 ${activePath.includes('/opinion') ? 'text-amber-500' : 'text-zinc-300'}`}>Opinión</a>
    </nav>
  </div>
</header>
